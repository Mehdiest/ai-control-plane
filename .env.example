APP_NAME="AI Control Plane"
ENVIRONMENT=development

# PostgreSQL connection string (async driver)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/control_plane

# Health checking
HEALTH_CHECK_INTERVAL_SECONDS=15
HEALTH_CHECK_TIMEOUT_SECONDS=5.0
UNHEALTHY_AFTER_FAILURES=3

# Security — generate a strong secret, e.g. python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=please-generate-a-strong-random-secret
JWT_ALGORITHM=HS256

# When false, requests without a valid Bearer JWT are rejected with 401.
ALLOW_ANONYMOUS_ACCESS=true

# Redis (Phase 3 — rate limiting counter store)
REDIS_URL=redis://localhost:6379/0

# Rate limiting
RATE_LIMIT_ENABLED=true
